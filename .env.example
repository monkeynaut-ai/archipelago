CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here
GITHUB_TOKEN=github-personal-access-token
ANTHROPIC_API_KEY=your-api-key-here
LOG_LEVEL=DEBUG

AF_MLFLOW_BASE_URL=
AF_MLFLOW_EXPERIMENT_ID=

# by dafault agent foundry pauses a container when the container fails. Set
# AGENT_FOUNDRY_PAUSE_ON_FAILURE=0 to autonatically removed failed containers.
AGENT_FOUNDRY_PAUSE_ON_FAILURE=<1 or 0>

# Route agent container HTTPS through a local fault-injection proxy. Set BOTH
# vars to enable; both empty disables. Used to test upstream-API failure handling.
# Cert lives in secrets/ (gitignored); copy from the mitmproxy sidecar with:
#   docker cp mitm-sidecar:/home/mitmproxy/.mitmproxy/mitmproxy-ca-cert.pem secrets/mitmproxy-ca.crt
ARCHIPELAGO_PROXY_URL=
ARCHIPELAGO_PROXY_CA_PATH=